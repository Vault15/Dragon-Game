{
    "version": 2,
    "builds": [
        {
            "src": "game.html",
            "use": "@vercel/static"
        },
        {
            "src": "sketch.js",
            "use": "@vercel/static"
        },
        {
            "src": "style.css",
            "use": "@vercel/static"
        },
        {
            "src": "*.png",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/game.html"
        }
    ]
}